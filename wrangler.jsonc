{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "cookiedle-worker",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "docs",
    "binding": "ASSETS"
  },
  // Analytics Engine — uncomment after enabling at dash.cloudflare.com > Workers > Analytics Engine
  // "analytics_engine_datasets": [
  //   { "binding": "ANALYTICS", "dataset": "cookiedle_events" }
  // ],
}
