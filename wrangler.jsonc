{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "cookiedle-worker",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "docs",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "COOKIEDLE_KV",
      "id": "2f9cc0b9cf2448cc889446f4bd8731b8",
      "remote": true
    }
  ]
}
